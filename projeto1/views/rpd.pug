doctype html
html
  head
    title R.P.D. - Departamento de Polícia
    style.
      body { background: #0b0d17; color: #cbd5e0; font-family: 'Courier New', monospace; padding: 50px; }
      .terminal { border-left: 5px solid #2b6cb0; padding-left: 20px; background: #1a202c; padding: 20px; }
      .warning { color: #f6ad55; font-weight: bold; }
  body
    h1 🚨 DELEGACIA DE RACCOON CITY (R.P.D.)
    div.terminal
      p > Localização: #[span.warning #{location}]
      p > Oficial de Plantão: #{officer}
      p > Missão Atual: #{objective}
      p > Status do Prédio: PORTAS TRANCADAS (MEDALHÕES NECESSÁRIOS)
    
    br
    a(href="/raccoon", style="color: #63b3ed") << Voltar para o Mapa da Cidade
